#!/usr/bin/env bash

# Terminal control functions
NORM(){ echo -en "\033[?12l\033[?25h";}

SHOW_SIG=true
FORCE_FONT=""
DO_CLEAR=true
DO_CIVIS=true
IS_PREVIEW=false

# Parse arguments
while [[ "$#" -gt 0 ]]; do
    case "$1" in
        --no-sig) SHOW_SIG=false ;;
        --no-clear) DO_CLEAR=false ;;
        --no-civis) DO_CIVIS=false ;;
        --preview) IS_PREVIEW=true; SHOW_SIG=false ;;
        --font) shift; FORCE_FONT="$1" ;;
        -*) ;; 
        *) [[ -z "$NAME" ]] && NAME="$1" ;;
    esac
    shift
done

# Load preference if name not passed
if [[ -z "${NAME// /}" ]]; then
    if [[ -f ~/.username ]]; then
        NAME=$(grep "^NAME=" ~/.username | cut -d= -f2- | tr -d '"')
    fi
fi
[[ -z "${NAME// /}" ]] && NAME="Promptify"

[[ "$DO_CLEAR" == "true" ]] && printf "\033[2J\033[H" >&2
[[ "$DO_CIVIS" == "true" ]] && tput civis >&2

# 1. Setup Logic
TERM_W=$(tput cols)
P_DIR="$PROMPTIFY_DIR"
[[ -z "$P_DIR" ]] && P_DIR="$HOME/.promptify"
F_SHADOW="$P_DIR/assets/ASCII-Shadow.flf"

if ! command -v figlet &> /dev/null; then
    CLEAN_LEN=$(( ${#NAME} + 8 ))
    OFFSET=$(( (TERM_W - CLEAN_LEN) / 2 ))
    [[ $OFFSET -lt 0 ]] && OFFSET=0
    printf "\r%${OFFSET}s\033[1;35m--- %s ---\033[0m\n" "" "$NAME" >&2
    return 0 2>/dev/null || exit 0
fi

# 2. Font Selection (V1 Style)
KERN=""
[[ ${#NAME} -lt 7 ]] && KERN="-k"

if [[ -n "$FORCE_FONT" ]]; then
    case "$FORCE_FONT" in
        "shadow") USE_FONT="$F_SHADOW" ;;
        "big")    USE_FONT="big"; KERN="" ;;
        "std")    USE_FONT="standard"; KERN="" ;;
        *)        USE_FONT="$F_SHADOW" ;;
    esac
else
    if [[ -f ~/.username ]]; then
        PREF_FONT=$(grep "^FONT=" ~/.username | cut -d= -f2- | tr -d '"')
    fi
    case "${PREF_FONT:-auto}" in
        "shadow") USE_FONT="$F_SHADOW" ;;
        "big")    USE_FONT="big"; KERN="" ;;
        "std")    USE_FONT="standard"; KERN="" ;;
        *)        USE_FONT="$F_SHADOW" ;;
    esac
fi

# Capture figlet output and check fit (V1 Core Logic)
check_fit() {
    local f_kern="$1"
    local f_font="$2"
    local f_name="$3"
    local f_max_w="$4"
    local max_w=0
    
    mapfile -t RAW_LINES < <(figlet ${f_kern:+"$f_kern"} -f "$f_font" -w 1000 "$f_name" 2>/dev/null)
    for line in "${RAW_LINES[@]}"; do
        [[ ${#line} -gt $max_w ]] && max_w=${#line}
    done
    [[ $max_w -le $((f_max_w - 12)) ]]
}

# Auto-fit logic (V1 Logic)
if ! check_fit "$KERN" "$USE_FONT" "$NAME" "$TERM_W"; then
    if [[ "$USE_FONT" != "standard" ]]; then
        USE_FONT="standard"
        KERN=""
        mapfile -t RAW_LINES < <(figlet -f "standard" -w 1000 "$NAME" 2>/dev/null)
    fi
fi

# Find Min Leading Space and Max Width
MIN_LEAD=999
MAX_LINE_W=0
for line in "${RAW_LINES[@]}"; do
    [[ -z "${line// /}" ]] && continue
    stripped="${line#"${line%%[! ]*}"}"
    lead_count=$(( ${#line} - ${#stripped} ))
    [[ $lead_count -lt $MIN_LEAD ]] && MIN_LEAD=$lead_count
done
[[ $MIN_LEAD -eq 999 ]] && MIN_LEAD=0

# Tighten lines
FINAL_LINES=()
for line in "${RAW_LINES[@]}"; do
    [[ -z "${line// /}" ]] && continue
    line="${line:$MIN_LEAD}"
    line="${line%"${line##*[![:space:]]}"}"
    FINAL_LINES+=("$line")
    [[ ${#line} -gt $MAX_LINE_W ]] && MAX_LINE_W=${#line}
done

# 3. Box Dimensions (RESTORED V1 DYNAMIC SIZING + EXTRA BREATHING ROOM)
# Increase base padding to +14 for better aesthetics
WIDTH=$((MAX_LINE_W + 14))

# V1 Smart Auto-Padding: Minimum 60% of terminal for look
MIN_TARGET=$(( TERM_W * 6 / 10 ))
[[ $WIDTH -lt $MIN_TARGET ]] && WIDTH=$MIN_TARGET

# Previews need stability, so we use a wider fixed range
if [[ "$IS_PREVIEW" == "true" ]]; then
    [[ $WIDTH -lt 72 ]] && WIDTH=72
    [[ $WIDTH -gt 78 ]] && WIDTH=78
fi

# ABSOLUTE LIMIT: Ensure it never exceeds terminal width but contains content
if [[ $WIDTH -gt $((TERM_W - 2)) ]]; then
    WIDTH=$((TERM_W - 2))
fi

# CRUCIAL: Box MUST be at least 4 chars wider than content to prevent "fading" through borders
if [[ $WIDTH -lt $((MAX_LINE_W + 4)) ]]; then
    WIDTH=$((MAX_LINE_W + 4))
fi

[[ $WIDTH -lt 40 ]] && WIDTH=40

# Padding to center content inside box (Balanced Centering)
# Add 1 before division to round up, which often looks more centered on terminals
BLOCK_PAD_L=$(( (WIDTH - 2 - MAX_LINE_W + 1) / 2 ))
[[ $BLOCK_PAD_L -lt 0 ]] && BLOCK_PAD_L=0

# Screen offset for box centering
OFFSET=$(( (TERM_W - WIDTH) / 2 ))
[[ $OFFSET -lt 0 ]] && OFFSET=0
SPACER=$(printf "%${OFFSET}s" "")

# Colorize with lolcat
if command -v lolcat &> /dev/null; then
    COLORED_BLOCK=$(printf "%s\n" "${FINAL_LINES[@]}" | lolcat -f 2>/dev/null)
    if [[ -n "$COLORED_BLOCK" ]]; then
        mapfile -t COLORED_LINES <<< "$COLORED_BLOCK"
    else
        COLORED_LINES=("${FINAL_LINES[@]}")
    fi
else
    COLORED_LINES=("${FINAL_LINES[@]}")
fi

# 4. Final Drawing
BOX_CLR="\033[1;34m" 
RESET="\033[0m"

H_LINE=""
for ((i=0; i<WIDTH-2; i++)); do
    H_LINE+="═"
done

printf "%b%b╔%s╗%b\n" "$SPACER" "$BOX_CLR" "$H_LINE" "$RESET" >&2

for i in "${!FINAL_LINES[@]}"; do
    line="${FINAL_LINES[i]}"
    colored_line="${COLORED_LINES[i]:-$line}"
    line_len=${#line}
    
    pad_r=$(( WIDTH - 2 - BLOCK_PAD_L - line_len ))
    [[ $pad_r -lt 0 ]] && pad_r=0
    
    # Robust Surgical Printing
    printf "%b%b║%b" "$SPACER" "$BOX_CLR" "$RESET" >&2
    printf "%*s" "$BLOCK_PAD_L" "" >&2
    printf "%s" "$colored_line" >&2
    printf "%*s" "$pad_r" "" >&2
    printf "%b║%b\n" "$BOX_CLR" "$RESET" >&2
done

printf "%b%b╚%s╝%b\n" "$SPACER" "$BOX_CLR" "$H_LINE" "$RESET" >&2

if [[ "$SHOW_SIG" == "true" ]]; then
    SIG_TEXT="Powered by Promptify ⚡︎"
    SIG_OFFSET=$(( OFFSET + WIDTH - ${#SIG_TEXT} - 2 ))
    [[ $SIG_OFFSET -lt 0 ]] && SIG_OFFSET=0
    printf "%*s\033[1;35mPowered by \033[1;36mPromptify \033[1;33m⚡︎\033[0m\n" "$SIG_OFFSET" "" >&2
fi

printf "\n" >&2
[[ "$DO_CIVIS" == "true" ]] && NORM
